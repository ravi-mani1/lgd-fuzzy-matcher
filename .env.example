# ── Authentication ────────────────────────────────────────────────────────
# JSON mapping of username → password (or PBKDF2 hash).
# Generate a hash: python -c "from utils import hash_password; print(hash_password('mypassword'))"
LGD_AUTH_USERS_JSON={"admin": "changeme"}

# Secret key for persistent login tokens (any random string).
LGD_AUTH_TOKEN_SECRET=change-this-to-a-random-secret

# ── API ───────────────────────────────────────────────────────────────────
# Optional API key — if set, all /match and /stats endpoints require X-API-Key header.
LGD_API_KEY=

# Max rows per API request (default 50000).
LGD_MAX_RECORDS=50000

# Max CSV upload size in bytes (default 50 MB).
LGD_MAX_CSV_BYTES=52428800
